<!DOCTYPE html>
<html lang="en">
    {% include "partials/_head.njk" %}
    <body>
        {% include "partials/_menu.njk" %}
        <main class="font-sans leading-normal tracking-normal pb-10 main-container">
            {% block content %}
                <div class="flex justify-center pt-0 lg:pt-8">
                    <article class="prose lg:prose-xl divide-y">
                        <div>
                            <h1 class="font-bold mt-12 mb-10">
                                {{ title }}
                            </h1>
                            {{ content | safe }}
                            <div class="mb-10 mt-20">
                                <p class="font-light mb-5 italic text-gray-800">Published {{ date|dateFormating }}</p>
                                <div class="flex flex-wrap">
                                    {% for category in categories %}
                                        <p class="badge mb-3 font-light select-none">{{ category }}</p>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                        {% if site.ko_fi_url %}
                            <div div="flex">
                                <p class="mt-14 mb-0 sm:mb-5">Writing good articles takes a lot of time and energy ⚡️</p>
                                <a aria-label="donate" target="_blank" href="{{ site.ko_fi_url }}">
                                    <p class="mt-3">Feel free to support me</p>
                                </a>
                            </div>
                        {% endif %}
                    </article>
                </div>
                {# {% include "partials/_nextPreviousPost.njk" %} #}
            {% endblock %}
            {% include "partials/_footer.njk" %}
        </main>
        <script defer src="/js/alpine.js?v=3.10.4"></script>
    </body>
</html>