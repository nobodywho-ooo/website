<!DOCTYPE html>
<html lang="en" class="bg-white dark:bg-neutral-900">
    {% include "partials/_head.njk" %}
    <body>
        {% include "partials/_menu.njk" %}
        <main class="font-sans leading-normal tracking-normal">
            {% block content %}
                <div class="flex justify-center pt-0 lg:pt-8">
                    <article class="prose lg:prose-xl dark:prose-invert divide-y overflow-x-hidden mx-auto max-w-2xl px-6 lg:max-w-4xl">
                        <div class="pt-12 sm:pt-32">
                            <h1 class="mt-12 mb-10 font-bold dark:text-white">
                                {{ title }}
                            </h1>
                            {{ content | safe }}
                            <div class="mb-10 mt-20">
                                <p class="font-light mb-5 italic text-gray-800 dark:text-white">Published {{ date|dateFormating }}</p>
                                <div class="flex flex-wrap gap-x-4">
                                    {% for category in categories %}
                                        <span class="inline-flex items-center rounded-full bg-gray-50 px-4 py-1.5 text-base font-medium text-gray-600 inset-ring
                                                inset-ring-gray-500/10 dark:bg-gray-400/10 dark:text-gray-400 dark:inset-ring-gray-400/20">
                                            {{ category }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </article>
                </div>
            {% endblock %}
            {% include "partials/_footer.njk" %}
        </main>
        <script src="/js/elements.js" type="module"></script>
        <script defer src="/js/alpine.js?v=3.10.4"></script>
    </body>
</html>