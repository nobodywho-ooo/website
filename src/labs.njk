---
layout: base
title: Labs
tags: pageHiddenInMenu
---

<div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8 py-24 sm:py-32">
    <h1 class="text-4xl font-semibold sm:text-5xl text-neutral-900 dark:text-white">Labs</h1>
    <p class="mt-4 text-xl text-neutral-400">Explore the labs building the models you can run locally.</p>

    <ul role="list" class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {% for lab in labs %}
            <li>
                <a
                    href="/labs/{{ lab.name | slug }}/"
                    aria-label="{{ lab.name }}"
                    class="group flex items-center gap-x-4 rounded-2xl p-5 inset-ring inset-ring-gray-300 transition-colors
                        hover:bg-gray-50 dark:inset-ring-white/10 dark:hover:bg-white/5">
                    <span
                        class="flex size-12 shrink-0 items-center justify-center rounded-xl bg-white p-2 text-neutral-700 ring-1 ring-black/5"
                        aria-hidden="true">
                        {{ lab.logo | inlineLogo | safe }}
                    </span>
                    <span class="text-lg font-semibold text-neutral-900 group-hover:text-primary dark:text-white">{{ lab.name }}</span>
                </a>
            </li>
        {% endfor %}
    </ul>
</div>
