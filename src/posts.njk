---
layout: base
title: Blog
order: 2
tags: page
pagination:
    data: collections.posts
    size: 10
    alias: posts
    reverse: true
---

<div class="py-24 sm:py-32">
    <div class="mx-auto max-w-2xl px-6 lg:max-w-4xl px-6 lg:px-8">
        <h2 class="text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white">Blog</h2>
        <p class="mt-2 text-lg/8 text-gray-600 dark:text-gray-300">News, tutorials & more.</p>
        <div class="mt-10 space-y-16 border-t border-gray-200 pt-10 sm:mt-16 sm:pt-16 dark:border-gray-700">
            {% for post in posts %}
                <article class=" flex flex-col items-start justify-between">
                    <div class="flex items-center gap-x-4 text-xs">
                        <time datetime="2020-03-16" class="text-gray-500 dark:text-gray-400">{{ post.date | dateFormating }}</time>
                        {% for category in post.data.categories %}
                            <a
                                href="#"
                                class="relative z-10 rounded-full bg-gray-50 px-3 py-1.5 font-medium text-gray-600 hover:bg-gray-100 dark:bg-gray-800/60
                                    dark:text-gray-300 dark:hover:bg-gray-800">{{ category }}</a>
                        {% endfor %}
                    </div>
                    <div class="group relative">
                        <a href="{{ post.url }}">
                            <h3 class="mt-3 text-xl text-gray-900 group-hover:text-gray-600 dark:text-white dark:group-hover:text-gray-300">
                                <span class="absolute inset-0"></span>
                                {{ post.data.title }}
                            </h3>
                            <p class="mt-2 line-clamp-3 text-sm/6 text-gray-600 dark:text-gray-400">{{ post.data.description }}</p>
                        </a>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</div>
{% include "partials/_pagination.njk" %}