{% macro deviceIcon(device, klass) %}{% if device === "smartphone" %}{{ smartphoneIcon(klass) }}{% elif device === "smartwatch" %}{{ smartwatchIcon(klass) }}{% elif device === "laptop" %}{{ laptopIcon(klass) }}{% elif device === "workstation" %}{{ workstationIcon(klass) }}{% endif %}{% endmacro %}

{% macro tagBadges(m, showLanguages=true) %}
    {% set badgeClass = "inline-flex items-center gap-x-1 rounded-full bg-neutral-100 px-2.5 py-1 text-xs font-medium text-neutral-700 dark:bg-white/10 dark:text-neutral-300" %}
    {% if m.parameterCountBillions or m.sizeGB or m.idealDeviceDeployment or (showLanguages and m.languages.length) or m.thinking or m.tags.length %}
        <div class="mt-3 flex flex-wrap gap-2">
            {% if m.parameterCountBillions %}
                <span class="{{ badgeClass }}">{{ cpuIcon("size-3.5") }}{% if m.parameterCountBillions < 1 %}{{ (m.parameterCountBillions * 1000) | round }}M{% else %}{{ m.parameterCountBillions }}B{% endif %}</span>
            {% endif %}
            {% if m.sizeGB %}
                <span class="{{ badgeClass }}">{{ sizeIcon("size-3.5") }}{{ m.sizeGB }} GB</span>
            {% endif %}
            {% if m.idealDeviceDeployment %}
                <span class="{{ badgeClass }}">{{ deviceIcon(m.idealDeviceDeployment, "size-3.5") }}{{ m.idealDeviceDeployment | capitalize }}</span>
            {% endif %}
            {% for tag in m.tags %}
                <span class="{{ badgeClass }}">{{ tag | capitalize }}</span>
            {% endfor %}
            {% if m.thinking %}
                <span class="{{ badgeClass }}">{{ bulbIcon("size-3.5") }}Thinking</span>
            {% endif %}
            {% if showLanguages and m.languages.length %}
                <span class="{{ badgeClass }}">{{ translateIcon("size-3.5") }}{{ m.languages.length }} languages</span>
            {% endif %}
        </div>
    {% endif %}
{% endmacro %}
