{% macro cpuIcon(klass) %}<svg class="{{ klass }} shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" /></svg>{% endmacro %}

{% macro sizeIcon(klass) %}<svg class="{{ klass }} shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>{% endmacro %}

{% macro bulbIcon(klass) %}<svg class="{{ klass }} shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>{% endmacro %}

{% macro tagBadges(m) %}
    {% set badgeClass = "inline-flex items-center gap-x-1 rounded-full bg-neutral-100 px-2.5 py-1 text-xs font-medium text-neutral-700 dark:bg-white/10 dark:text-neutral-300" %}
    {% if m.parameterCountBillions or m.sizeGB or m.tags.length %}
        <div class="mt-3 flex flex-wrap gap-2">
            {% if m.parameterCountBillions %}
                <span class="{{ badgeClass }}">{{ cpuIcon("size-3.5") }}{{ m.parameterCountBillions }}B</span>
            {% endif %}
            {% if m.sizeGB %}
                <span class="{{ badgeClass }}">{{ sizeIcon("size-3.5") }}{{ m.sizeGB }} GB</span>
            {% endif %}
            {% for tag in m.tags %}
                {% if tag | lower !== "recommended" %}
                    <span class="{{ badgeClass }}">{% if tag | lower === "thinking" %}{{ bulbIcon("size-3.5") }}{% endif %}{{ tag | capitalize }}</span>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
{% endmacro %}
