{
  "name": "nobodywho.ooo",
  "description": "NobodyWho's website",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "npm run build:css && npm-run-all -p dev:*",
    "build": "run-s build:*",
    "dev:11ty": "eleventy --serve",
    "dev:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/tailwind-dist.css --watch",
    "build:11ty": "eleventy",
    "build:css": "tailwindcss -i src/assets/css/tailwind.css -o src/assets/css/tailwind-dist.css"
  },
  "repository": "https://github.com/nobodywho-ooo/website",
  "author": "NobodyWho <services@nobodywho.ooo>",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "alpinejs": "^3.15.8",
    "autoprefixer": "^10.4.27",
    "eleventy-plugin-lazyimages": "^2.1.2",
    "markdown-it": "^14.1.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
